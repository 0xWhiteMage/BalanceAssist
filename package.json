{
  "name": "balance-assist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\" && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:test": "node scripts/apply-test-migrations.mjs",
    "test:db:prepare": "node scripts/apply-test-migrations.mjs",
    "test:db": "vitest run --no-file-parallelism tests/integration/database-schema.test.ts tests/integration/rate-limit.test.ts tests/integration/session-capability.test.ts",
    "test:supabase:service-role": "vitest run tests/integration/supabase-service-role.test.ts",
    "test:e2e": "playwright install chromium && playwright test"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.54.0",
    "next": "^15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.20",
    "jsdom": "26.1.0",
    "pg": "^8.22.0",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vitest": "3.2.7",
    "yaml": "^2.9.0",
    "zod-to-json-schema": "^3.25.2"
  }
}
