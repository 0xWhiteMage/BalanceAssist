{
  "name": "balance-assist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\" && next build",
    "start": "next start",
    "lint": "eslint --no-eslintrc --config .eslintrc.json --resolve-plugins-relative-to . --max-warnings 0 .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:test": "node scripts/apply-test-migrations.mjs",
    "db:migrate:recover-production": "node scripts/recover-production-migrations.mjs",
    "db:migrate:production-crm": "node scripts/apply-production-crm-migrations.mjs",
    "test:db:prepare": "node scripts/apply-test-migrations.mjs",
    "test:db": "vitest run --no-file-parallelism tests/integration/database-schema.test.ts tests/integration/rate-limit.test.ts tests/integration/session-capability.test.ts tests/integration/release-proof-journey.test.ts tests/integration/monday-release-proof.test.ts",
    "test:release-proof:http": "vitest run --no-file-parallelism tests/integration/release-proof-http.test.ts",
    "test:supabase": "node scripts/test-supabase.mjs",
    "test:supabase:service-role": "vitest run tests/integration/supabase-service-role.test.ts",
    "test:e2e": "playwright install chromium && playwright test",
    "monday:schema:verify": "node scripts/verify-monday-schema.mjs"
  },
  "overrides": {
    "@tootallnate/once": "2.0.1",
    "@vercel/node": {
      "path-to-regexp": "6.3.0"
    },
    "@vercel/remix-builder": {
      "path-to-regexp": "6.3.0"
    },
    "minimatch": "10.2.3",
    "path-to-regexp": "8.4.0",
    "postcss": "8.5.16",
    "tar": "7.5.16",
    "undici": "6.27.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.54.0",
    "next": "^15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.20",
    "jsdom": "26.1.0",
    "pg": "^8.22.0",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vercel": "56.1.0",
    "vitest": "3.2.7",
    "yaml": "^2.9.0",
    "zod-to-json-schema": "^3.25.2"
  }
}
