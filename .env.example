# Supabase server access (the URL name is retained for deployed configuration compatibility)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
# Required before analysis-consented file uploads can be enabled. This bucket must be private.
SUPABASE_PRIVATE_UPLOAD_BUCKET=temporary-attachments

# LLM
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Telegram relay
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USERNAMES=
# Optional. Enables the 15-minute scheduling flow in the preview widget and team /schedule command.
CALENDLY_URL=

# Security
SETUP_TOKEN=
INTERNAL_DISPATCH_SECRET=
CRON_SECRET=
ALLOWED_ORIGINS=https://balancestudio.tv,https://www.balancestudio.tv
# Required in production on Vercel, whose x-vercel-forwarded-for header is sanitized by the deployment platform.
TRUSTED_CLIENT_IP_HEADER=x-vercel-forwarded-for
# Test-only: disposable PostgreSQL integration database and fake Telegram HTTP boundary.
TEST_DATABASE_URL=
TELEGRAM_API_BASE_URL=

# Monday CRM projection. Both lanes remain disabled until the runbook release gates are approved.
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=18421762586
MONDAY_API_VERSION=2026-07
MONDAY_UPSERT_ENABLED=false
MONDAY_CLEANUP_ENABLED=false
MONDAY_AUTH_MODE=service_token
MONDAY_AUTH_APPROVAL_REF=
